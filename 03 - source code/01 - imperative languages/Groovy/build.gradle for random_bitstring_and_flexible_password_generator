plugins {
    id 'groovy'
    id 'application'
    id 'com.gradleup.shadow' version '9.3.1'  // Replace with your Gradle version
}

repositories {
    mavenCentral()
}

dependencies {
    implementation 'org.apache.groovy:groovy-all:5.0.4'  // Replace with your required Groovy version
}

application {
    mainClass = 'random_bitstring_and_flexible_password_generator'  // Replace with your Groovy script's main class name
}

tasks.named('shadowJar') {
    archiveBaseName.set('random_bitstring_and_flexible_password_generator')
    archiveVersion.set('')
    archiveClassifier.set('')
}
